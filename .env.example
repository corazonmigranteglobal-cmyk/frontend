NEXT_PUBLIC_APP_NAME=Corazón Migrante
NEXT_PUBLIC_APP_URL=http://localhost:4173
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Puerto preferido del frontend en desarrollo. yarn dev busca 4173 y, si está ocupado, prueba 4174, 4175...
NEXT_PUBLIC_DEV_PORT=4173
NEXT_PUBLIC_DEV_PORT_SCAN_LIMIT=30

# CMS público real del backend: GET /api/v1/public/pages/:slug
NEXT_PUBLIC_CMS_LIBRARY_SLUG=biblioteca

# Vista pública configurada para la landing principal.
# IMPORTANTE: por compatibilidad con el frontend anterior, NEXT_PUBLIC_PUBLIC_VIEW_SLUG puede contener el ID.
# Regla principal actual: GET /api/v1/public-views/:id
NEXT_PUBLIC_PUBLIC_VIEW_MODE=public-view-id
NEXT_PUBLIC_PUBLIC_VIEW_SLUG=1
NEXT_PUBLIC_PUBLIC_VIEW_ID=
NEXT_PUBLIC_PUBLIC_VIEW_CODE=
NEXT_PUBLIC_PUBLIC_VIEW_ENDPOINT=
NEXT_PUBLIC_PUBLIC_VIEW_ELEMENT_ENDPOINT=

# Modos/endpoints soportados:
# public-view-id -> GET /api/v1/public-views/:id
# page-by-id     -> GET /api/v1/public/pages/by-id/:id
# page-slug      -> GET /api/v1/public/pages/:slug
# auto           -> si slug/id es numérico usa /api/v1/public-views/:id; si no, /api/v1/public/pages/:slug
# También puedes forzar endpoint con tokens :id, :slug y :code:
# NEXT_PUBLIC_PUBLIC_VIEW_ENDPOINT=/api/v1/public-views/:id
# NEXT_PUBLIC_PUBLIC_VIEW_ENDPOINT=/api/v1/public/pages/by-id/:id
# NEXT_PUBLIC_PUBLIC_VIEW_ENDPOINT=/api/v1/public/pages/:slug
# NEXT_PUBLIC_PUBLIC_VIEW_ELEMENT_ENDPOINT=/api/v1/public-views/:id/elements/:code
# NEXT_PUBLIC_PUBLIC_VIEW_ELEMENT_ENDPOINT=/api/v1/public/pages/:slug/elements/:code

# Servidor de archivos / assets públicos. Se pueden sobreescribir en producción.
NEXT_PUBLIC_FILE_SERVER_LOGO_URL=https://storage.googleapis.com/vistas_publicas_assets/global_assets/media/LOGO%20CORAZON%20MIGRANTE.png
